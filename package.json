{
  "name": "html2md-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @html2md/core build && pnpm --filter @html2md/web dev",
    "build": "pnpm --filter @html2md/core build && pnpm --filter @html2md/web build",
    "build:local": "pnpm --filter @html2md/core build && pnpm --filter @html2md/web build:local",
    "start": "pnpm --filter @html2md/web start",
    "start:local": "pnpm --filter @html2md/web start:local",
    "lint": "pnpm --filter @html2md/web lint",
    "test": "pnpm -r test",
    "test:web": "pnpm --filter @html2md/web test",
    "test:core": "pnpm --filter @html2md/core test"
  }
}
